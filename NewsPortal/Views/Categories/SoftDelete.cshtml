@model NewsPOrtal.DAL.Models.Category
@{
    ViewBag.Title = "Delete";
}

@{ 
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - NewsPortal</title>
    <link rel="stylesheet" href="~/Content/bootstrap.css" />
    <link rel="stylesheet" href="~/Content/site.css" />
    <script src="~/Scripts/modernizr-2.8.3.js"></script>

</head>
<body style="background-color:#98f4fb">
    <div class=" container">
   <h3 style="color:#d9534f">Are you sure you want to delete this?</h3>
    
       <dl class="dl-horizontal">
            <dt>
                @Html.DisplayNameFor(model => model.Code)
            </dt>

            <dd>
                @Html.DisplayFor(model => model.Code)
            </dd>
            <dt>
                @Html.DisplayNameFor(model => model.CreatedBy)
            </dt>

            <dd>
                @Html.DisplayFor(model => model.CreatedBy)
            </dd>

            <dt>
                @Html.DisplayNameFor(model => model.CreatedOn)
            </dt>

            <dd>
                @Html.DisplayFor(model => model.CreatedOn)
            </dd>

        </dl>

    <form asp-action="SoftDelete" method="post">
        @Html.AntiForgeryToken()

       <div class="form-actions no-color" style="margin-left: 360px;
    margin-bottom: 10px;">
           <input type="submit" value="Delete" class="btn btn-danger" /> 

           <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
       </div>
    </form>

    <script src="~/Scripts/jquery-3.3.1.js"></script>
    <script src="~/Scripts/bootstrap.js"></script>
   </div>
</body>
</html>
