@model NewsPOrtal.DAL.ViewModels.CategoryViewModel


<form asp-controller="NewsPortal" asp-action="CreateComment" method="post" class="add-comment">
    <div class="row">
        <div class="col-md-12">
            <h3>Add Comment</h3>
        </div>
        <div class="col-md-12">
            <div class="form-group">
                <input class="form-control" required name="Name" type="text" placeholder="Full Name" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <textarea rows="4" name="Body" required class="form-control" placeholder="Your comment"></textarea>
                <span asp-validation-for="Body" class="text-danger"></span>
            </div>
            <input type="hidden" name="Article_Id" value="@Model.Article_Id" />
            <div class="form-group">
                <input type="submit" name="submit" value="Add Comment" class="form-control" />
             </div>
        </div>
    </div>
</form>
